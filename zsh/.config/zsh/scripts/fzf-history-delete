#!/usr/bin/env python3
"""Remove matching command entries from a zsh history file."""

from __future__ import annotations

import os
import re
import sys
import tempfile


EXTENDED_HISTORY_RE = re.compile(rb"^: \d+:\d+;(.*)$")


def main() -> int:
    if len(sys.argv) < 3:
        return 1

    histfile = sys.argv[1]
    command = " ".join(sys.argv[2:])
    if not command or not os.path.isfile(histfile):
        return 1

    command_bytes = command.encode("utf-8", "surrogateescape")
    temp_fd = -1
    temp_path = None

    try:
        temp_fd, temp_path = tempfile.mkstemp(
            dir=os.path.dirname(histfile) or ".",
            prefix=f"{os.path.basename(histfile)}.tmp.",
        )

        with open(histfile, "rb") as src, os.fdopen(temp_fd, "wb") as dst:
            temp_fd = -1
            for raw_line in src:
                line = raw_line[:-1] if raw_line.endswith(b"\n") else raw_line
                match = EXTENDED_HISTORY_RE.match(line)
                entry = match.group(1) if match else line
                if entry == command_bytes:
                    continue
                dst.write(raw_line)

        os.replace(temp_path, histfile)
        return 0
    except OSError:
        return 1
    finally:
        if temp_fd != -1:
            os.close(temp_fd)
        if temp_path is not None:
            try:
                os.unlink(temp_path)
            except FileNotFoundError:
                pass
            except OSError:
                pass


if __name__ == "__main__":
    raise SystemExit(main())
