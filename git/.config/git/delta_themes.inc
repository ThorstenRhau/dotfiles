[delta "claude-dark"]
	blame-palette = "#191918 #262624 #383835 #5a5955 #8b8780"
	commit-decoration-style = "#5a5955" bold box ul
	dark = true
	file-decoration-style = "#5a5955"
	file-style = "#e8e4dc"
	hunk-header-decoration-style = "#5a5955" box ul
	hunk-header-file-style = bold
	hunk-header-line-number-style = bold "#8b8780"
	hunk-header-style = file line-number syntax
	line-numbers-left-style = "#5a5955"
	line-numbers-minus-style = bold "#C07070"
	line-numbers-plus-style = bold "#7DA47A"
	line-numbers-right-style = "#5a5955"
	line-numbers-zero-style = "#8b8780"
	minus-style = syntax "#362728"
	minus-non-emph-style = syntax "#362728"
	minus-emph-style = bold syntax "#4a3030"
	minus-empty-line-marker-style = syntax "#362728"
	plus-style = syntax "#292f26"
	plus-non-emph-style = syntax "#292f26"
	plus-emph-style = bold syntax "#344030"
	plus-empty-line-marker-style = syntax "#292f26"
	map-styles = \
		bold purple => syntax "#3d2a4a", \
		bold blue => syntax "#283d55", \
		bold cyan => syntax "#2a3d38", \
		bold yellow => syntax "#3d3820"
	# Should match the name of the bat theme
	syntax-theme = claude_dark

[delta "claude-light"]
	blame-palette = "#faf9f5 #edece8 #eae9e5 #c4c0b8 #7d7870"
	commit-decoration-style = "#7d7870" bold box ul
	light = true
	file-decoration-style = "#7d7870"
	file-style = "#2a2920"
	hunk-header-decoration-style = "#7d7870" box ul
	hunk-header-file-style = bold
	hunk-header-line-number-style = bold "#7d7870"
	hunk-header-style = file line-number syntax
	line-numbers-left-style = "#7d7870"
	line-numbers-minus-style = bold "#B05555"
	line-numbers-plus-style = bold "#527E50"
	line-numbers-right-style = "#7d7870"
	line-numbers-zero-style = "#7d7870"
	minus-style = syntax "#f0d0d0"
	minus-non-emph-style = syntax "#f0d0d0"
	minus-emph-style = bold syntax "#e8b8b8"
	minus-empty-line-marker-style = syntax "#f0d0d0"
	plus-style = syntax "#d6ead4"
	plus-non-emph-style = syntax "#d6ead4"
	plus-emph-style = bold syntax "#c0dcbe"
	plus-empty-line-marker-style = syntax "#d6ead4"
	map-styles = \
		bold purple => syntax "#e8daf0", \
		bold blue => syntax "#d0e0f0", \
		bold cyan => syntax "#d0ece8", \
		bold yellow => syntax "#f0ead0"
	# Should match the name of the bat theme
	syntax-theme = claude_light
